rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read: if true;
      allow write: if true; // In real app, restrict to admin
    }
    match /orders/{orderId} {
      allow read: if true; // In real app, restrict to admin
      allow write: if true;
    }
  }
}
